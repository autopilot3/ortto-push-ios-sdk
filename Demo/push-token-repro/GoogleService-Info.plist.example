<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>replace-with-firebase-api-key</string>
	<key>BUNDLE_ID</key>
	<string>com.ortto.pushtokenrepro</string>
	<key>GCM_SENDER_ID</key>
	<string>replace-with-gcm-sender-id</string>
	<key>GOOGLE_APP_ID</key>
	<string>replace-with-google-app-id</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>PROJECT_ID</key>
	<string>replace-with-firebase-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>replace-with-firebase-storage-bucket</string>
</dict>
</plist>
