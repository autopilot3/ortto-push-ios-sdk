// Copy this file to Local.xcconfig and fill in your Ortto configuration.
// This is where ALL Ortto config lives — BuildDefaults.xcconfig declares these
// empty. Local.xcconfig is gitignored, so your keys stay off version control.
//
// The $() segment expands to nothing, producing https:// — it only stops Xcode
// from reading the // as an xcconfig comment.

// Your account's capture endpoint. Pick your region (AU/EU/US) or instance.
ORTTO_API_ENDPOINT = https:/$()/capture-api-au.ortto.app/

// Fill in the key for the target(s) you run. Leave the other blank.
ORTTO_APNS_APP_KEY = paste_apns_app_key_here
ORTTO_FCM_APP_KEY = paste_fcm_app_key_here

// Optional: set to demo in-app notifications (widgets). Leave blank to stay push-only.
ORTTO_CAPTURE_JS_URL = paste_capture_js_url_here
